# Copy to .env and fill in. Never commit the real .env.

# --- LLM access (llm/client.py) ---
# One of: anthropic | openrouter | ollama
PROCESSFORGE_LLM_PROVIDER=
# Optional: leave unset to store the key in the OS keyring instead via
# `python -m llm.secrets set <anthropic|openrouter>` (see also: status, delete).
PROCESSFORGE_LLM_API_KEY=
PROCESSFORGE_MODEL_EXTRACT=
PROCESSFORGE_MODEL_REASON=
PROCESSFORGE_MODEL_ARBITER=
# Only used when PROCESSFORGE_LLM_PROVIDER=ollama. Default: http://localhost:11434
PROCESSFORGE_OLLAMA_HOST=

# --- Knowledge base ---
# SQLite file path. Keep it outside the repo tree in production (§9); default below is dev-only.
PROCESSFORGE_DB_PATH=./kb/processforge.db

# --- API (api/main.py) ---
# Auth is real per-operator login, not an env var: create accounts via
# `python -m auth.users create <username>` (see auth/users.py), then obtain a
# bearer token via POST /auth/login. No env var is needed for auth.
# Requests per client IP per minute allowed on the protected endpoints. Default: 30.
PROCESSFORGE_RATE_LIMIT_PER_MINUTE=

# --- Build-session logging (§6.1) ---
# Optional external webhook that mirrors council-loop iteration notes. Missing
# URL/token or an unreachable endpoint both no-op with a warning — never blocks the build loop.
BUILD_LOG_URL=
BUILD_LOG_TOKEN=
